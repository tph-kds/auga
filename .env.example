# Environment Configuration Example
# Copy this file to .env and adjust values as needed

# Application
LOG_LEVEL=INFO
APP_ENV=development
DEBUG=false

# API
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=sqlite:///data/memory/memory.db

# Training
DEFAULT_TIMESTEPS=100000
DEFAULT_ALGORITHM=PPO

# Sandbox
SANDBOX_TIMEOUT=3600
SANDBOX_MEMORY_LIMIT=2g
ENABLE_SANDBOX=true

# RL Parameters
LEARNING_RATE=0.0003
BATCH_SIZE=64
GAMMA=0.99

# Ray (optional)
RAY_ENABLE=false
RAY_ADDRESS=auto

# MLflow (optional)
MLFLOW_TRACKING_URI=file:./mlruns
ENABLE_MLFLOW=false

# Docker
DOCKER_IMAGE=rl-sandbox:latest

# Security
VALIDATION_LEVEL=standard
MAX_INPUT_LENGTH=10000

# ── LLM Advisor (Inference Phase) ──────────────────────────────────────────
# Optional LLM layer for strategic decision-making during agent inference.
# Leave LLM_PROVIDER=none to run in pure-RL mode (no API key needed).

# Provider: none | gemini | openrouter
LLM_PROVIDER=none

# Google Gemini Flash (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# OpenRouter — routes to GPT-4o, Claude, Mistral, etc.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
